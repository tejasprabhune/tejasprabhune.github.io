---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Tejas Prabhune">
  <section class="hero">
    <div class="hero-inner">
      <p class="page-name">tejas prabhune</p>
      <p class="bio">
        i'm a berkeley new-grad working on <span class="animate-color">gpu efficiency</span>
        and user simulation for post-training.
      </p>

      <ul class="contact-list">
        <li><a href="mailto:prabhune@berkeley.edu">prabhune@berkeley.edu</a></li>
        <li><a href="https://twitter.com/tejas_prabhune" target="_blank" rel="noopener">@tejas_prabhune</a></li>
        <li><a href="https://www.linkedin.com/in/tejas-prabhune/" target="_blank" rel="noopener">linkedin</a></li>
        <li><a href="https://scholar.google.com/citations?user=QI1zl84AAAAJ&hl=en" target="_blank" rel="noopener">google scholar</a></li>
      </ul>

      <ul class="work-list">
        <li class="work-item">
          <span class="work-role">agentic city simulation (2nd place, claude build day)</span>
          <span class="work-dot" aria-hidden="true"></span>
          <span class="work-place">
            <a href="https://simfrancisco.org" target="_blank" rel="noopener">simfrancisco</a>
          </span>
        </li>
        <li class="work-item">
          <span class="work-role">multilingual post-training &amp; ml systems</span>
          <span class="work-dot" aria-hidden="true"></span>
          <span class="work-place">Wispr</span>
        </li>
        <li class="work-item">
          <span class="work-role">virtual avatars, bci &amp; speech modeling</span>
          <span class="work-dot" aria-hidden="true"></span>
          <span class="work-place">Berkeley Speech Group</span>
        </li>
        <li class="work-item">
          <span class="work-role">parliamentary debate &amp; coaching</span>
          <span class="work-dot" aria-hidden="true"></span>
          <span class="work-place">berkeley</span>
        </li>
        <li class="work-item">
          <span class="work-role">side quests</span>
          <span class="work-dot" aria-hidden="true"></span>
          <span class="work-place">
            <a href="https://tejasprabhune.github.io/bv-registry/about.html" target="_blank" rel="noopener">bv</a>,
            <a href="https://tejasprabhune.github.io/kiln" target="_blank" rel="noopener">kiln</a>,
            <a href="https://tejasprabhune.github.io/kern" target="_blank" rel="noopener">kern</a>,
            <a href="https://goldenturn.org" target="_blank" rel="noopener">goldenturn</a>,
            <a href="https://goldenturn.org/recordings" target="_blank" rel="noopener">npdavideos</a>
